{
  "expo": {
    "name": "DoubanRefugee",
    "slug": "douban-refugee",
    "description": "Mobile companion for importing scraped Douban history and sharing transfer files.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "doubanrefugee",
    "platforms": ["ios", "android"],
    "githubUrl": "https://github.com/otterlymavis/DoubanRefugee",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.otterlymavis.doubanrefugee",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.otterlymavis.doubanrefugee",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    }
  }
}
