{
  "manifest_version": 3,
  "name": "DoubanRefugee Transfer Extractor",
  "version": "0.1.0",
  "description": "Scrape your own Douban history into local transfer files.",
  "permissions": ["activeTab", "clipboardWrite", "cookies", "scripting", "storage", "tabs"],
  "host_permissions": ["https://*.douban.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "DoubanRefugee",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.douban.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
