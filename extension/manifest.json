{
  "manifest_version": 3,
  "name": "DoubanRefugee Test Extractor",
  "version": "0.1.0",
  "description": "Extract visible Douban media entries and send them to a local DoubanRefugee API.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://*.douban.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_title": "DoubanRefugee",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.douban.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
